{
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		".claude.git/objects.git/subtree-cache.hg/store.dart_tool": true,
		".claude/**": true,
		".claude": true
	},
	"anyaiChat.permissions.yoloMode": true,
	"anyaiChat.projectInstructions.enabled": true,
	"anyaiChat.projectInstructions.filePath": ".claude/instructions.md",
	"anyaiChat.reminders.enabled": false,
	"anyaiChat.reminders.frequency": 5,
	"anyaiChat.discriminator.enabled": false,
	"anyaiChat.discriminator.provider": "gemini",
	"anyaiChat.discriminator.model": "gemini-2.0-flash",
	"anyaiChat.discriminator.autoReview": true,
	"anyaiChat.discriminator.temperature": 0.3,
	"anyaiChat.discriminator.integrationLevel": "monitoring",
	"anyaiChat.discriminator.autoEvaluation": true,
	"anyaiChat.discriminator.fallbackStrategy": "best-performance",
	"anyaiChat.discriminator.metricsUpdateInterval": 2000,
	"anyaiChat.discriminator.planReview.enabled": false,
	"anyaiChat.discriminator.planReview.minConfidence": 0.7,
	"anyaiChat.discriminator.planReview.timeoutMs": 10000,
	"anyaiChat.discriminator.planReview.allowUserOverride": true,
	"anyaiChat.discriminator.planReview.failOpen": true,
	"anyaiChat.discriminator.changeReview.enabled": false,
	"anyaiChat.discriminator.changeReview.realtime": true,
	"anyaiChat.discriminator.changeReview.minConfidence": 0.6,
	"anyaiChat.discriminator.changeReview.timeoutMs": 8000,
	"anyaiChat.discriminator.changeReview.blockOnCritical": false,
	"anyaiChat.discriminator.fixChecker.cacheTimeout": 300000,
	"anyaiChat.discriminator.fixChecker.enableRegressionCheck": true,
	"anyaiChat.discriminator.fixChecker.accuracyThreshold": 90,
	"anyaiChat.discriminator.fixChecker.completenessThreshold": 90,
	"anyaiChat.discriminator.fixChecker.maxConcurrentFiles": 5,
	"anyaiChat.discriminator.openaiModel": "gpt-4o",
	"anyaiChat.sessionRevalidation.maxConcurrentFiles": 5,
	"anyaiChat.sessionRevalidation.similarityThreshold": 0.6,
	"anyaiChat.sessionRevalidation.reportFormat": "both",
	"anyaiChat.sessionRevalidation.retryAttempts": 3,
	"anyaiChat.sessionRevalidation.enableDiagnostics": true,
	"anyaiChat.sessionRevalidation.timeoutMs": 30000,
	"anyaiChat.conversations.maxMessagesOnLoad": 400,
	"anyaiChat.conversations.loadBatchSize": 100,
	"anyaiChat.worklog.enabled": false,
	"search.exclude": {
		".claude/**": true,
		".claude": true
	},
	"files.watcherExclude": {
		".claude/**": true,
		".claude": true
	}
}